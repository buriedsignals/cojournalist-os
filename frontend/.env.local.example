# Manual frontend env override for Supabase-auth development.
#
# Private repo daily flow:
#   npm run dev                     # local FastAPI auth broker + hosted account data on localhost
#   npm run dev:hosted-broker       # diagnostic: use the deployed broker path
#   npm run dev:supabase-local-demo # local Supabase auth + local-only demo workspace
#
# Copy this file to .env.local only if you need a manual override or OSS-style
# raw Vite env setup:
#   cp .env.local.example .env.local
#
# Then:
#   cd frontend && nvm use && npm install && npm run dev:raw
#   open http://localhost:5173/login
#
# See docs/architecture/developer-guide.md for the local auth modes.

# Which auth path to use. "supabase" routes the auth store to auth-supabase.ts.
# Set PUBLIC_MUCKROCK_ENABLED=true to exercise the MuckRock broker login flow.
PUBLIC_DEPLOYMENT_TARGET=supabase

# Supabase project URL. Anon key is published & safe to commit in this example.
PUBLIC_SUPABASE_URL=https://gfmdziplticfoakhrfpt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdmbWR6aXBsdGljZm9ha2hyZnB0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njc2MDYzMjIsImV4cCI6MjA4MzE4MjMyMn0.Liz22BqK2qfHBcIsIJxGTT4VvMzfBE_yRFraVrUPKq4
PUBLIC_MUCKROCK_ENABLED=false
PUBLIC_LOCAL_DEMO_MODE=false
# For private-repo local MuckRock dev, point the browser at the local FastAPI
# broker and keep the post-login callback pinned to localhost.
# PUBLIC_MUCKROCK_BROKER_URL=http://localhost:5173/api/auth/login
PUBLIC_MUCKROCK_POST_LOGIN_REDIRECT=http://localhost:5173/auth/callback

# Where the workspace api-client sends REST calls. Post-cutover target.
# (Pre-cutover alternate — comment out the Supabase URL above and use:)
# VITE_API_URL=https://www.cojournalist.ai/api
VITE_API_URL=https://gfmdziplticfoakhrfpt.supabase.co/functions/v1

# MapTiler (geocoding for LocationAutocomplete). Optional for workspace smoke
# testing — only needed if you open a Location Scout config form.
PUBLIC_MAPTILER_API_KEY=
