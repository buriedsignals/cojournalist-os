# Local dev against prod Supabase (Plan 04 testing)
#
# Copy to .env.local (gitignored) and fill values:
#   cp .env.local.example .env.local
#
# Then:
#   cd frontend && nvm use && npm install && npm run dev
#   open http://localhost:5173/login    (/login renders email/password when
#                                        PUBLIC_DEPLOYMENT_TARGET=supabase)
#
# See docs/testing-local.md for the full flow.

# Which auth path to use. "supabase" routes the auth store to auth-supabase.ts
# (email/password via @supabase/supabase-js). Any other value (or unset) keeps
# MuckRock as the default — same behaviour as prod SaaS today.
PUBLIC_DEPLOYMENT_TARGET=supabase

# Supabase project URL. Anon key is published & safe to commit in this example.
PUBLIC_SUPABASE_URL=https://gfmdziplticfoakhrfpt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdmbWR6aXBsdGljZm9ha2hyZnB0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njc2MDYzMjIsImV4cCI6MjA4MzE4MjMyMn0.Liz22BqK2qfHBcIsIJxGTT4VvMzfBE_yRFraVrUPKq4

# Where the workspace api-client sends REST calls. Post-cutover target.
# (Pre-cutover alternate — comment out the Supabase URL above and use:)
# VITE_API_URL=https://www.cojournalist.ai/api
VITE_API_URL=https://gfmdziplticfoakhrfpt.supabase.co/functions/v1

# MapTiler (geocoding for LocationAutocomplete). Optional for workspace smoke
# testing — only needed if you open a Location Scout config form.
PUBLIC_MAPTILER_API_KEY=
