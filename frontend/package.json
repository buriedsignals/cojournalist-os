{
  "name": "cojournalist-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy localStorage globalVariable baseLocale",
    "dev": "npm run paraglide:compile && svelte-kit sync && vite dev",
    "build": "npm run paraglide:compile && svelte-kit sync && vite build",
    "preview": "svelte-kit sync && vite preview",
    "check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.17.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "svelte": "^5.2.9",
    "svelte-check": "^4.1.3",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.10.0",
    "@supabase/supabase-js": "^2.100.1",
    "dompurify": "^3.2.3",
    "lucide-svelte": "^0.468.0",
    "marked": "^17.0.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0 <11.0.0"
  }
}
