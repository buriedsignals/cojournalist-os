FROM mirror.gcr.io/node:22-alpine

WORKDIR /app

# Copy package files first for better caching
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy application code (excluding node_modules via .dockerignore)
COPY . .

# Convert build args to .env file for Vite dev server
ARG PUBLIC_DEPLOYMENT_TARGET
ARG PUBLIC_SUPABASE_URL
ARG PUBLIC_SUPABASE_ANON_KEY
ARG PUBLIC_MAPTILER_API_KEY
RUN echo "PUBLIC_DEPLOYMENT_TARGET=${PUBLIC_DEPLOYMENT_TARGET}" > .env \
 && echo "PUBLIC_SUPABASE_URL=${PUBLIC_SUPABASE_URL}" >> .env \
 && echo "PUBLIC_SUPABASE_ANON_KEY=${PUBLIC_SUPABASE_ANON_KEY}" >> .env \
 && echo "PUBLIC_MAPTILER_API_KEY=${PUBLIC_MAPTILER_API_KEY}" >> .env

# Expose port
EXPOSE 5173

# Command will be overridden by docker-compose
CMD ["npm", "run", "dev:raw", "--", "--host", "0.0.0.0", "--port", "5173", "--strictPort"]
